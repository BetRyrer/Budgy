# --- Base de données ---
POSTGRES_DB=budgy
POSTGRES_USER=budgy
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# --- Backend (Symfony) ---
APP_ENV=dev
APP_SECRET=change-me-please-generate-a-random-secret
# Doit rester cohérent avec les variables POSTGRES_* ci-dessus
DATABASE_URL=postgresql://budgy:change-me@database:5432/budgy?serverVersion=16&charset=utf8

# --- Nginx (expose l'API backend) ---
NGINX_PORT=8080

# --- Frontend (Vite) ---
FRONTEND_PORT=5173
# URL de l'API vue depuis le navigateur de l'utilisateur
VITE_API_URL=http://localhost:8080/api
